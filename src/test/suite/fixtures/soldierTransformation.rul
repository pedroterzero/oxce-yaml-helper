soldierTransformation:
  - name: STR_TRANSFORMATION_WITHOUT_SOLDIER_TYPES
    # allowedSoldierTypes:
    #   - STR_FOOBAR

  # positive case: transformation WITH allowedSoldierTypes (should NOT warn)
  - name: STR_TRANSFORMATION_WITH_SOLDIER_TYPES
    allowedSoldierTypes:
      - YOURTYPE

  - name: STR_TRANSFORMATION_SOLDIERBONUSTYPE_TEST
    soldierBonusType: STR_DUMMY_BONUS
  # missing
  - name: STR_TRANSFORMATION_SOLDIERBONUSTYPE_TEST_MISSING
    soldierBonusType: STR_DUMMY_NON_EXISTING_REFERENCE
  # incorrect
  - name: STR_TRANSFORMATION_SOLDIERBONUSTYPE_TEST_INCORRECT
    soldierBonusType: STR_DUMMY_RESEARCH
